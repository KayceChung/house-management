# House Management System - Environment Variables

# 🔗 Google Apps Script Web App URL
# Replace YOUR_SCRIPT_ID with your actual Google Apps Script ID
# Format: https://script.google.com/macros/s/{SCRIPT_ID}/usercodeapp
REACT_APP_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/usercodeapp

# 💱 Utility Prices (in Vietnamese Dong)
REACT_APP_ELECTRIC_PRICE=3000
REACT_APP_WATER_PRICE=5000

# 🏢 Spreadsheet name
REACT_APP_SPREADSHEET_NAME=HOUSE-MANAGEMENT
